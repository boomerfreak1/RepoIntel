# Required
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repo

# AI Mode: "local" (Ollama, default) or "cloud" (API keys)
AI_MODE=local

# Admin password for indexing via UI
ADMIN_PASSWORD=admin

# Cloud AI keys (only needed if AI_MODE=cloud)
# MISTRAL_API_KEY=your_mistral_key
# MISTRAL_CHAT_MODEL=mistral-small-latest
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key

# Optional: define project domains (auto-inferred from folders if not set)
# PROJECT_DOMAINS=["backend","frontend","infrastructure"]

# Ollama (local mode)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:1b

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Data Storage (Railway: /data with persistent volume)
DATA_DIR=/data

# Server
PORT=3000
